---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Presage — Predict anything. Earn your edge.", description = "Launch a prediction market in 60 seconds, earn 30% of every trade — the most creator-generous prediction market platform in crypto." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Presage",
      "description": "Launch a prediction market in 60 seconds, earn 30% of every trade — the most creator-generous prediction market platform in crypto.",
      "url": "https://community-prediction-market.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.13 0.035 240); color: oklch(0.95 0.005 240);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
