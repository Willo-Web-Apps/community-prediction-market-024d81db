---
import Base from '../layouts/Base.astro';
---
<Base
  title="Presage — Predict anything. Earn your edge."
  description="Launch a prediction market in 60 seconds, earn 30% of every trade — the most creator-generous platform in the space."
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO — War room aesthetic, amber glow, dramatic type
       ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col justify-center overflow-hidden noise-overlay" style="
    background:
      radial-gradient(ellipse 80% 60% at 75% -10%,  oklch(0.76 0.16 65 / 0.12) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 90% 25%,   oklch(0.76 0.14 55 / 0.08) 0%, transparent 55%),
      radial-gradient(ellipse 40% 50% at 10% 80%,   oklch(0.40 0.08 240 / 0.30) 0%, transparent 60%),
      linear-gradient(160deg, oklch(0.16 0.042 245) 0%, oklch(0.12 0.035 235) 60%, oklch(0.10 0.030 230) 100%);
  ">
    <!-- Dot grid subtle pattern -->
    <div class="absolute inset-0 pointer-events-none" style="
      background-image: radial-gradient(circle at 1px 1px, oklch(0.95 0.005 240 / 0.04) 1px, transparent 0);
      background-size: 28px 28px;
      mask-image: radial-gradient(ellipse 90% 85% at 50% 40%, black 30%, transparent 80%);
    "></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 pt-24 pb-16 lg:pt-32 lg:pb-24">
      <div class="grid lg:grid-cols-[1fr_420px] gap-16 items-center">

        <!-- Left: Copy -->
        <div>
          <!-- Label -->
          <div class="animate-slide-up inline-flex items-center gap-2 mb-8">
            <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
            <span class="text-xs font-semibold tracking-[0.18em] uppercase text-brand-500 font-body">Creator-First Prediction Markets</span>
          </div>

          <!-- Headline -->
          <h1 class="animate-slide-up delay-100 font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl leading-[0.95] tracking-tight text-surface-950 mb-6">
            Your&nbsp;prediction.<br/>
            Your&nbsp;market.<br/>
            <span style="color: oklch(0.76 0.16 65);">Your&nbsp;earnings.</span>
          </h1>

          <!-- Sub -->
          <p class="animate-slide-up delay-200 font-body font-light text-lg sm:text-xl text-surface-800 max-w-lg leading-relaxed mb-10">
            Launch a prediction market in 60 seconds. Earn <strong class="font-semibold text-surface-950">30% of every trade</strong> your market generates — the most creator-generous split in the space.
          </p>

          <!-- CTAs -->
          <div class="animate-slide-up delay-300 flex flex-wrap gap-4 items-center mb-12">
            <div class="relative">
              <!-- Glow halo behind button -->
              <div class="absolute inset-0 rounded-lg blur-xl opacity-60" style="background: oklch(0.76 0.16 65 / 0.45); transform: scale(1.15);"></div>
              <a href="#create"
                 class="relative inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg font-body font-semibold text-base transition-all duration-200 hover:scale-[1.02] hover:brightness-110"
                 style="background: oklch(0.76 0.16 65); color: oklch(0.12 0.035 235);">
                Create my first market
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
              </a>
            </div>
            <a href="#how-it-works"
               class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-body font-medium text-base text-surface-900 transition-all duration-200 hover:text-surface-950"
               style="border: 1px solid oklch(0.95 0.005 240 / 0.15);">
              See how it works
            </a>
          </div>

          <!-- Micro-proof: stats strip -->
          <div class="animate-slide-up delay-400 grid grid-cols-3 gap-0 max-w-lg">
            <div class="pr-6 border-r border-surface-400/30">
              <div class="font-display text-3xl sm:text-4xl" style="color: oklch(0.76 0.16 65);">14k+</div>
              <div class="font-body font-light text-xs text-surface-800 mt-1 tracking-wide">Markets created</div>
            </div>
            <div class="px-6 border-r border-surface-400/30">
              <div class="font-display text-3xl sm:text-4xl text-surface-950">$2.4M</div>
              <div class="font-body font-light text-xs text-surface-800 mt-1 tracking-wide">Trading volume</div>
            </div>
            <div class="pl-6">
              <div class="font-display text-3xl sm:text-4xl" style="color: oklch(0.76 0.16 65);">$180k</div>
              <div class="font-body font-light text-xs text-surface-800 mt-1 tracking-wide">Paid to creators</div>
            </div>
          </div>
        </div>

        <!-- Right: Product card mockup -->
        <div class="animate-fade-in delay-300 hidden lg:block animate-float">
          <!-- Market card -->
          <div class="rounded-xl p-0 overflow-hidden" style="
            background: oklch(0.17 0.042 242);
            border: 1px solid oklch(0.95 0.005 240 / 0.10);
            box-shadow: 0 32px 64px oklch(0.08 0.02 240 / 0.8), 0 0 0 1px oklch(0.76 0.16 65 / 0.08);
          ">
            <!-- Card header -->
            <div class="px-5 pt-5 pb-4" style="border-bottom: 1px solid oklch(0.95 0.005 240 / 0.07);">
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="font-body text-[10px] font-semibold tracking-[0.15em] uppercase" style="color: oklch(0.76 0.16 65);">LIVE MARKET</span>
                <span class="font-body text-[10px] font-medium text-surface-800 bg-surface-200/60 px-2 py-0.5 rounded">Closes Nov 30</span>
              </div>
              <h3 class="font-body font-semibold text-surface-950 text-sm leading-snug">
                Will Bitcoin exceed $120,000 before end of Q4 2025?
              </h3>
            </div>

            <!-- Probability bars -->
            <div class="px-5 py-4" style="border-bottom: 1px solid oklch(0.95 0.005 240 / 0.07);">
              <div class="space-y-2.5">
                <div>
                  <div class="flex justify-between mb-1.5">
                    <span class="font-body text-xs font-medium text-surface-950">Yes</span>
                    <span class="font-body text-xs font-semibold" style="color: oklch(0.76 0.16 65);">63%</span>
                  </div>
                  <div class="h-1.5 rounded-full" style="background: oklch(0.22 0.038 240);">
                    <div class="h-1.5 rounded-full" style="width: 63%; background: linear-gradient(to right, oklch(0.76 0.16 65), oklch(0.78 0.14 60));"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between mb-1.5">
                    <span class="font-body text-xs font-medium text-surface-800">No</span>
                    <span class="font-body text-xs font-medium text-surface-800">37%</span>
                  </div>
                  <div class="h-1.5 rounded-full" style="background: oklch(0.22 0.038 240);">
                    <div class="h-1.5 rounded-full" style="width: 37%; background: oklch(0.35 0.020 240);"></div>
                  </div>
                </div>
              </div>

              <!-- Trade buttons -->
              <div class="grid grid-cols-2 gap-2 mt-4">
                <button class="py-2 rounded-md font-body font-semibold text-xs transition-all" style="background: oklch(0.76 0.16 65 / 0.15); color: oklch(0.76 0.16 65); border: 1px solid oklch(0.76 0.16 65 / 0.25);">Buy YES</button>
                <button class="py-2 rounded-md font-body font-semibold text-xs transition-all" style="background: oklch(0.22 0.038 240 / 0.8); color: oklch(0.72 0.015 240); border: 1px solid oklch(0.95 0.005 240 / 0.10);">Buy NO</button>
              </div>
            </div>

            <!-- Creator earnings badge -->
            <div class="px-5 py-3.5">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                  <div class="w-7 h-7 rounded-full flex items-center justify-center" style="background: oklch(0.76 0.16 65 / 0.15);">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="oklch(0.76 0.16 65)"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/></svg>
                  </div>
                  <div>
                    <div class="font-body text-[10px] text-surface-800">Created by <span class="text-surface-900 font-medium">@cryptoanalyst</span></div>
                    <div class="font-body text-[10px] font-semibold" style="color: oklch(0.76 0.16 65);">Earned $342 from this market</div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-body text-[10px] text-surface-800">Volume</div>
                  <div class="font-body text-xs font-semibold text-surface-950">$1,140</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Second card: teaser -->
          <div class="mt-3 rounded-xl px-5 py-3.5 flex items-center justify-between" style="
            background: oklch(0.16 0.040 241);
            border: 1px solid oklch(0.95 0.005 240 / 0.07);
          ">
            <div>
              <div class="font-body text-xs font-medium text-surface-900">Will the Fed cut rates in December?</div>
              <div class="font-body text-[10px] text-surface-800 mt-0.5">2,847 traders · $47.2k volume</div>
            </div>
            <div class="font-display text-lg" style="color: oklch(0.76 0.16 65);">78%</div>
          </div>
          <div class="mt-2 rounded-xl px-5 py-3.5 flex items-center justify-between" style="
            background: oklch(0.15 0.038 240);
            border: 1px solid oklch(0.95 0.005 240 / 0.05);
          ">
            <div>
              <div class="font-body text-xs font-medium text-surface-800">Will ETH hit $5k before BTC hits $150k?</div>
              <div class="font-body text-[10px] text-surface-800/70 mt-0.5">1,203 traders · $22.8k volume</div>
            </div>
            <div class="font-display text-lg text-surface-900">41%</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none" style="background: linear-gradient(to bottom, transparent, oklch(0.13 0.035 240));"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TRUST BAR — Logos / proof signals
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-12" style="background: oklch(0.13 0.035 240);">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="amber-divider mb-10"></div>
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        <span class="font-body text-xs font-semibold tracking-[0.18em] uppercase text-surface-800">Featured in</span>
        <span class="font-display text-base text-surface-800/50">The Block</span>
        <span class="font-display text-base text-surface-800/50">Bankless</span>
        <span class="font-display text-base text-surface-800/50">Decrypt</span>
        <span class="font-display text-base text-surface-800/50">CoinDesk</span>
        <span class="font-display text-base text-surface-800/50">Farcaster</span>
      </div>
      <div class="amber-divider mt-10"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       HOW IT WORKS — 3-step visual (product-led)
       ═══════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-24 lg:py-32" style="background: oklch(0.13 0.035 240);">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="mb-16">
        <span class="font-body text-xs font-semibold tracking-[0.18em] uppercase text-brand-500 block mb-4">How it works</span>
        <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl text-surface-950 leading-tight max-w-xl">
          From idea to market<br/>in under a minute.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-0">

        <!-- Step 1 -->
        <div class="relative pr-8 md:pr-12 pb-8 md:pb-0" style="border-right: 1px solid oklch(0.76 0.16 65 / 0.15);">
          <div class="mb-6">
            <span class="font-display text-6xl sm:text-7xl" style="color: oklch(0.76 0.16 65 / 0.18);">01</span>
          </div>
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: oklch(0.76 0.16 65 / 0.12); border: 1px solid oklch(0.76 0.16 65 / 0.25);">
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="oklch(0.76 0.16 65)"><path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z"/></svg>
          </div>
          <h3 class="font-body font-semibold text-xl text-surface-950 mb-3">Name your question</h3>
          <p class="font-body font-light text-surface-800 leading-relaxed text-base">Write any yes/no question about the world — sports, crypto, politics, culture, your community. If people care, it's a market.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative px-8 md:px-12 pb-8 md:pb-0 mt-8 md:mt-0" style="border-right: 1px solid oklch(0.76 0.16 65 / 0.15);">
          <div class="mb-6">
            <span class="font-display text-6xl sm:text-7xl" style="color: oklch(0.76 0.16 65 / 0.18);">02</span>
          </div>
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: oklch(0.76 0.16 65 / 0.12); border: 1px solid oklch(0.76 0.16 65 / 0.25);">
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="oklch(0.76 0.16 65)"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" clip-rule="evenodd"/></svg>
          </div>
          <h3 class="font-body font-semibold text-xl text-surface-950 mb-3">Set rules &amp; deploy</h3>
          <p class="font-body font-light text-surface-800 leading-relaxed text-base">Set a resolution date, choose a resolver (oracle or community vote), add a seed liquidity amount. Deploy in one transaction.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative pl-8 md:pl-12 mt-8 md:mt-0" style="border-top: 1px solid oklch(0.76 0.16 65 / 0.12);">
          <div class="mb-6">
            <span class="font-display text-6xl sm:text-7xl" style="color: oklch(0.76 0.16 65 / 0.18);">03</span>
          </div>
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: oklch(0.76 0.16 65 / 0.12); border: 1px solid oklch(0.76 0.16 65 / 0.25);">
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="oklch(0.76 0.16 65)"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.732 6.232a2.5 2.5 0 013.536 3.536L6.5 15.536a1 1 0 01-1.414 0l-1.086-1.086a1 1 0 010-1.414l5.732-5.804z" clip-rule="evenodd"/></svg>
          </div>
          <h3 class="font-body font-semibold text-xl text-surface-950 mb-3">Earn as traders pile in</h3>
          <p class="font-body font-light text-surface-800 leading-relaxed text-base">Share your market link. Every trade generates fees — you keep 30%, automatically, on-chain. The more it spreads, the more you earn.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FEATURE DEEP-DIVES — Alternating left/right
       ═══════════════════════════════════════════════════════════ -->
  <section id="features" class="py-24 lg:py-32 relative overflow-hidden" style="background: oklch(0.14 0.038 242);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 100% 50%, oklch(0.76 0.16 65 / 0.04) 0%, transparent 65%);"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
      <div class="mb-16">
        <span class="font-body text-xs font-semibold tracking-[0.18em] uppercase text-brand-500 block mb-4">Why Presage</span>
        <h2 class="font-display text-4xl sm:text-5xl text-surface-950 leading-tight max-w-2xl">
          Built for creators who have insight — and deserve to own it.
        </h2>
      </div>

      <!-- Feature 1: 30% creator fee -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-24 lg:mb-32">
        <div>
          <div class="inline-block font-body text-xs font-semibold tracking-[0.15em] uppercase px-3 py-1 rounded mb-6" style="background: oklch(0.76 0.16 65 / 0.12); color: oklch(0.76 0.16 65);">Creator earnings</div>
          <h3 class="font-display text-3xl sm:text-4xl text-surface-950 leading-tight mb-5">
            30% of every trade.<br/>No cap. No catch.
          </h3>
          <p class="font-body font-light text-surface-800 text-lg leading-relaxed mb-6">
            Every time someone trades on a market you created, 30% of the protocol fee goes straight to your wallet — on-chain, automatic, every single trade. Polymarket gives creators zero. Entrave gives 20%. We give 30%.
          </p>
          <div class="grid grid-cols-3 gap-4">
            <div class="rounded-lg p-4 text-center" style="background: oklch(0.17 0.042 242); border: 1px solid oklch(0.95 0.005 240 / 0.08);">
              <div class="font-display text-2xl text-surface-800/40 mb-1">0%</div>
              <div class="font-body text-xs text-surface-800/60">Polymarket</div>
            </div>
            <div class="rounded-lg p-4 text-center" style="background: oklch(0.17 0.042 242); border: 1px solid oklch(0.95 0.005 240 / 0.08);">
              <div class="font-display text-2xl text-surface-800/60 mb-1">20%</div>
              <div class="font-body text-xs text-surface-800/60">Entrave</div>
            </div>
            <div class="rounded-lg p-4 text-center" style="background: oklch(0.76 0.16 65 / 0.10); border: 1px solid oklch(0.76 0.16 65 / 0.30);">
              <div class="font-display text-2xl mb-1" style="color: oklch(0.76 0.16 65);">30%</div>
              <div class="font-body text-xs font-semibold" style="color: oklch(0.76 0.16 65 / 0.8);">Presage ✓</div>
            </div>
          </div>
        </div>
        <div class="rounded-xl p-7" style="background: oklch(0.17 0.042 242); border: 1px solid oklch(0.95 0.005 240 / 0.08);">
          <!-- Earnings simulation visual -->
          <div class="mb-5">
            <div class="font-body text-xs font-semibold tracking-[0.15em] uppercase text-surface-800 mb-1">Creator earnings simulator</div>
            <div class="font-body text-xs text-surface-800/60">Based on 1% protocol fee, 30% creator split</div>
          </div>
          <div class="space-y-4">
            <div class="flex items-center justify-between py-3" style="border-bottom: 1px solid oklch(0.95 0.005 240 / 0.07);">
              <div>
                <div class="font-body font-medium text-sm text-surface-900">$10k volume market</div>
                <div class="font-body text-xs text-surface-800/60 mt-0.5">100 trades · avg $100</div>
              </div>
              <div class="text-right">
                <div class="font-body font-semibold text-base" style="color: oklch(0.76 0.16 65);">$30 earned</div>
                <div class="font-body text-xs text-surface-800/60">per market</div>
              </div>
            </div>
            <div class="flex items-center justify-between py-3" style="border-bottom: 1px solid oklch(0.95 0.005 240 / 0.07);">
              <div>
                <div class="font-body font-medium text-sm text-surface-900">$100k volume market</div>
                <div class="font-body text-xs text-surface-800/60 mt-0.5">500 trades · avg $200</div>
              </div>
              <div class="text-right">
                <div class="font-body font-semibold text-base" style="color: oklch(0.76 0.16 65);">$300 earned</div>
                <div class="font-body text-xs text-surface-800/60">per market</div>
              </div>
            </div>
            <div class="flex items-center justify-between py-3">
              <div>
                <div class="font-body font-medium text-sm text-surface-900">10 active markets</div>
                <div class="font-body text-xs text-surface-800/60 mt-0.5">avg $50k volume each</div>
              </div>
              <div class="text-right">
                <div class="font-display text-2xl" style="color: oklch(0.76 0.16 65);">$1,500</div>
                <div class="font-body text-xs text-surface-800/60">monthly passive</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Amber divider -->
      <div class="amber-divider mb-24 lg:mb-32"></div>

      <!-- Feature 2: Open market creation -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-24 lg:mb-32">
        <!-- Visual: tags/topics cloud -->
        <div class="order-2 lg:order-1 rounded-xl p-7" style="background: oklch(0.17 0.042 242); border: 1px solid oklch(0.95 0.005 240 / 0.08);">
          <div class="font-body text-xs font-semibold tracking-[0.15em] uppercase text-surface-800 mb-5">Active market categories</div>
          <div class="flex flex-wrap gap-2">
            <span class="font-body text-sm font-medium px-3 py-1.5 rounded-full" style="background: oklch(0.76 0.16 65 / 0.12); color: oklch(0.76 0.16 65); border: 1px solid oklch(0.76 0.16 65 / 0.20);">Crypto prices</span>
            <span class="font-body text-sm px-3 py-1.5 rounded-full" style="background: oklch(0.20 0.038 240); color: oklch(0.72 0.015 240); border: 1px solid oklch(0.95 0.005 240 / 0.08);">US Elections</span>
            <span class="font-body text-sm px-3 py-1.5 rounded-full" style="background: oklch(0.20 0.038 240); color: oklch(0.72 0.015 240); border: 1px solid oklch(0.95 0.005 240 / 0.08);">AI milestones</span>
            <span class="font-body text-sm px-3 py-1.5 rounded-full" style="background: oklch(0.76 0.16 65 / 0.08); color: oklch(0.78 0.13 65); border: 1px solid oklch(0.76 0.16 65 / 0.15);">DAO proposals</span>
            <span class="font-body text-sm px-3 py-1.5 rounded-full" style="background: oklch(0.20 0.038 240); color: oklch(0.72 0.015 240); border: 1px solid oklch(0.95 0.005 240 / 0.08);">Sports outcomes</span>
