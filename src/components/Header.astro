---
---
<header class="sticky top-0 z-50" style="
  background: oklch(0.13 0.035 240 / 0.85);
  backdrop-filter: blur(20px) saturate(1.3);
  border-bottom: 1px solid oklch(0.95 0.005 240 / 0.07);
">
  <nav class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-7 h-7 rounded flex items-center justify-center" style="background: oklch(0.76 0.16 65);">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="oklch(0.12 0.035 235)">
          <path d="M2 12l4-8 3 5 2-3 3 6H2z"/>
        </svg>
      </div>
      <span class="font-display text-xl tracking-tight" style="color: oklch(0.95 0.005 240);">Presage</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="font-body text-sm font-medium transition-colors duration-150" style="color: oklch(0.72 0.015 240);" onmouseover="this.style.color='oklch(0.95 0.005 240)'" onmouseout="this.style.color='oklch(0.72 0.015 240)'">How it works</a>
      <a href="#features" class="font-body text-sm font-medium transition-colors duration-150" style="color: oklch(0.72 0.015 240);" onmouseover="this.style.color='oklch(0.95 0.005 240)'" onmouseout="this.style.color='oklch(0.72 0.015 240)'">Features</a>
      <a href="/blog" class="font-body text-sm font-medium transition-colors duration-150" style="color: oklch(0.72 0.015 240);" onmouseover="this.style.color='oklch(0.95 0.005 240)'" onmouseout="this.style.color='oklch(0.72 0.015 240)'">Blog</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#" class="hidden sm:block font-body text-sm font-medium transition-colors duration-150" style="color: oklch(0.72 0.015 240);">Sign in</a>
      <a href="#create"
         class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg font-body font-semibold text-sm transition-all duration-200 hover:opacity-90"
         style="background: oklch(0.76 0.16 65); color: oklch(0.12 0.035 235);">
        Launch a market
        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
      </a>
    </div>
  </nav>
</header>
